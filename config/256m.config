# 生效位置：目标元数据：在目标解析阶段生效。
CONFIG_HAS_FPU=y

# 生效位置：目标元数据：在目标解析阶段生效。
CONFIG_HAS_DT_OVERLAY_SUPPORT=y

# 生效位置：构建配置：在 make defconfig 解析后生效。
CONFIG_AUDIO_SUPPORT=y

# 生效位置：构建配置：在 make defconfig 解析后生效。
CONFIG_GPIO_SUPPORT=y

# 生效位置：构建配置：在 make defconfig 解析后生效。
CONFIG_PCI_SUPPORT=y

# 生效位置：构建配置：在 make defconfig 解析后生效。
CONFIG_PCIE_SUPPORT=y

