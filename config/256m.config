CONFIG_DEFAULT_luci-app-package-manager=y

# 生效位置：设备默认包：由目标 profile 默认选择。
CONFIG_DEFAULT_luci-app-ttyd=y

# 生效位置：设备默认包：由目标 profile 默认选择。
CONFIG_DEFAULT_luci-compat=y

