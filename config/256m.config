# TR3000 256MB 精简构建配置
# 仅保留会生效的启用项，以及必须显式关闭的覆盖项。

# 生效位置：构建系统：启用内核模块支持。
CONFIG_MODULES=y

# 生效位置：构建系统：标记当前配置已初始化。
CONFIG_HAVE_DOT_CONFIG=y

# 生效位置：构建主机：限定在 Linux 环境生效。
CONFIG_HOST_OS_LINUX=y

# 生效位置：构建目标：选择 MediaTek 平台。
CONFIG_TARGET_mediatek=y

# 生效位置：构建目标：选择 Filogic 子平台。
CONFIG_TARGET_mediatek_filogic=y

# 生效位置：设备目标：生成 Cudy TR3000 v1 256MB 固件。
CONFIG_TARGET_mediatek_filogic_DEVICE_cudy_tr3000-v1-256mb=y

# 生效位置：目标元数据：声明当前目标存在子平台。
CONFIG_HAS_SUBTARGETS=y

# 生效位置：目标元数据：声明当前目标存在设备配置。
CONFIG_HAS_DEVICES=y

# 生效位置：目标元数据：指定目标板族。
CONFIG_TARGET_BOARD="mediatek"

# 生效位置：目标元数据：指定目标子平台。
CONFIG_TARGET_SUBTARGET="filogic"

# 生效位置：目标元数据：指定设备 profile。
CONFIG_TARGET_PROFILE="DEVICE_cudy_tr3000-v1-256mb"

# 生效位置：目标架构：指定软件包架构目录。
CONFIG_TARGET_ARCH_PACKAGES="aarch64_cortex-a53"

# 生效位置：编译优化：指定 Cortex-A53 默认优化参数。
CONFIG_DEFAULT_TARGET_OPTIMIZATION="-Os -pipe -mcpu=cortex-a53"

# 生效位置：目标架构：指定 CPU 类型。
CONFIG_CPU_TYPE="cortex-a53"

# 生效位置：内核版本：选择 Linux 6.6。
CONFIG_LINUX_6_6=y

# 生效位置：设备默认包：由目标 profile 默认选择。
CONFIG_DEFAULT_autocore-arm=y

# 生效位置：设备默认包：由目标 profile 默认选择。
CONFIG_DEFAULT_automount=y

# 生效位置：设备默认包：由目标 profile 默认选择。
CONFIG_DEFAULT_base-files=y

# 生效位置：设备默认包：由目标 profile 默认选择。
CONFIG_DEFAULT_block-mount=y

# 生效位置：设备默认包：由目标 profile 默认选择。
CONFIG_DEFAULT_ca-bundle=y

# 生效位置：设备默认包：由目标 profile 默认选择。
CONFIG_DEFAULT_default-settings-chn=y

# 生效位置：设备默认包：由目标 profile 默认选择。
CONFIG_DEFAULT_dnsmasq-full=y

# 生效位置：设备默认包：由目标 profile 默认选择。
CONFIG_DEFAULT_dropbear=y

# 生效位置：设备默认包：由目标 profile 默认选择。
CONFIG_DEFAULT_ethtool=y

# 生效位置：设备默认包：由目标 profile 默认选择。
CONFIG_DEFAULT_firewall4=y

# 生效位置：设备默认包：由目标 profile 默认选择。
CONFIG_DEFAULT_fitblk=y

# 生效位置：设备默认包：由目标 profile 默认选择。
CONFIG_DEFAULT_fstools=y

