CONFIG_USES_DEVICETREE=y

# 生效位置：构建配置：在 make defconfig 解析后生效。
CONFIG_USES_INITRAMFS=y

# 生效位置：构建配置：在 make defconfig 解析后生效。
CONFIG_USES_SEPARATE_INITRAMFS=y

# 生效位置：构建配置：在 make defconfig 解析后生效。
CONFIG_USES_SQUASHFS=y

# 生效位置：构建配置：在 make defconfig 解析后生效。
CONFIG_EMMC_SUPPORT=y

# 生效位置：构建配置：在 make defconfig 解析后生效。
CONFIG_NAND_SUPPORT=y

# 生效位置：目标架构：在交叉编译和内核配置阶段生效。
CONFIG_ARCH_64BIT=y

# 生效位置：构建配置：在 make defconfig 解析后生效。
CONFIG_USES_ROOTFS_PART=y

# 生效位置：目标架构：在交叉编译和内核配置阶段生效。
CONFIG_aarch64=y

# 生效位置：目标架构：在交叉编译和内核配置阶段生效。
CONFIG_ARCH="aarch64"

# 生效位置：构建配置：在 make defconfig 解析后生效。
CONFIG_EXTERNAL_CPIO=""

# 生效位置：固件镜像：启用 SquashFS 根文件系统。
CONFIG_TARGET_ROOTFS_SQUASHFS=y

# 生效位置：固件镜像：设置 SquashFS 块大小。
CONFIG_TARGET_SQUASHFS_BLOCK_SIZE=256

# 生效位置：固件镜像：启用 UBIFS 空闲空间修正。
CONFIG_TARGET_UBIFS_FREE_SPACE_FIXUP=y

# 生效位置：构建目标：在固件镜像选择阶段生效。
CONFIG_TARGET_UBIFS_JOURNAL_SIZE=""

# 生效位置：固件镜像：设置根分区大小。
CONFIG_TARGET_ROOTFS_PARTSIZE=160

# 生效位置：构建产物：生成镜像信息 JSON。
CONFIG_JSON_OVERVIEW_IMAGE_INFO=y

# 生效位置：软件包安全：启用签名包。
CONFIG_SIGNED_PACKAGES=y

# 生效位置：软件包安全：校验软件包签名。
CONFIG_SIGNATURE_CHECK=y

# 生效位置：下载安全：校验证书。
CONFIG_DOWNLOAD_CHECK_CERTIFICATE=y

# 生效位置：构建配置：在 make defconfig 解析后生效。
CONFIG_SHADOW_PASSWORDS=y

# 生效位置：构建产物：在固件中包含构建配置。
CONFIG_INCLUDE_CONFIG=y

# 生效位置：内核功能：随固件内核配置生效。
CONFIG_KERNEL_BUILD_USER=""

# 生效位置：内核功能：随固件内核配置生效。
CONFIG_KERNEL_BUILD_DOMAIN=""

# 生效位置：内核功能：保留内核日志输出。
CONFIG_KERNEL_PRINTK=y

# 生效位置：内核功能：启用 swap 支持。
CONFIG_KERNEL_SWAP=y

# 生效位置：发布内核裁剪：关闭 debugfs。
# CONFIG_KERNEL_DEBUG_FS is not set

# 生效位置：发布内核裁剪：关闭符号表。
# CONFIG_KERNEL_KALLSYMS is not set

# 生效位置：发布内核裁剪：关闭内核调试框架。
# CONFIG_KERNEL_DEBUG_KERNEL is not set

# 生效位置：发布内核裁剪：关闭调试信息。
# CONFIG_KERNEL_DEBUG_INFO is not set

# 生效位置：发布内核裁剪：关闭精简调试信息。
# CONFIG_KERNEL_DEBUG_INFO_REDUCED is not set

# 生效位置：内核编译：设置栈帧告警阈值。
CONFIG_KERNEL_FRAME_WARN=2048

# 生效位置：内核功能：启用异步 I/O。
CONFIG_KERNEL_AIO=y

# 生效位置：内核功能：启用 io_uring。
CONFIG_KERNEL_IO_URING=y

# 生效位置：内核功能：启用文件句柄接口。
CONFIG_KERNEL_FHANDLE=y

# 生效位置：内核功能：启用 fanotify。
CONFIG_KERNEL_FANOTIFY=y

# 生效位置：发布内核裁剪：关闭 Magic SysRq。
# CONFIG_KERNEL_MAGIC_SYSRQ is not set

# 生效位置：发布内核裁剪：关闭 coredump。
# CONFIG_KERNEL_COREDUMP is not set

# 生效位置：发布内核裁剪：关闭 ELF core。
# CONFIG_KERNEL_ELF_CORE is not set

# 生效位置：发布内核裁剪：关闭内核日志时间戳。
# CONFIG_KERNEL_PRINTK_TIME is not set

# 生效位置：内核功能：启用 cgroup 基础支持。
