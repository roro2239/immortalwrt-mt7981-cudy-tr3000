{
  "luci-app-home-dashboard": {
    "description": "Grant access to home dashboard",
    "read": {
      "ubus": {
        "system": [
          "board",
          "info"
        ],
        "network.interface": [
          "status"
        ]
      },
      "file": {
        "/etc/opkg/distfeeds.conf": [
          "read"
        ],
        "/proc/stat": [
          "read"
        ],
        "/sys/class/net/*/statistics/rx_bytes": [
          "read"
        ],
        "/sys/class/net/*/statistics/tx_bytes": [
          "read"
        ],
        "/sys/class/thermal/thermal_zone*/temp": [
          "read"
        ],
        "/sys/class/thermal/thermal_zone*/type": [
          "read"
        ]
      }
    },
    "write": {
      "file": {
        "/etc/opkg/distfeeds.conf": [
          "write"
        ]
      }
    }
  }
}
